recursive-include runner/Sources *.swift
include runner/SpecterQARunner.xcodeproj/project.pbxproj
include runner/Package.swift
include runner/build.sh
include runner/launch.sh
# runner_source/Sources is populated at build time from runner/Sources via setup.py.
# The following non-Swift runner_source files are still shipped verbatim.
include src/specterqa/ios/runner_source/SpecterQARunner.xcodeproj/project.pbxproj
include src/specterqa/ios/runner_source/Package.swift
include src/specterqa/ios/runner_source/build.sh
include src/specterqa/ios/runner_source/launch.sh
recursive-include examples *.yaml *.yml *.md
recursive-include tests *.py
include README.md
include LICENSE
include CHANGELOG.md
