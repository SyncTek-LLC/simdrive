# SimDrive Cloud API — environment variable template
# Copy to .env for local development; set as Railway variables in production.
# NEVER commit real values. This file contains only variable names + descriptions.

# ── License signing ──────────────────────────────────────────────────────────

# Ed25519 verify (public) key — hex-encoded 32 bytes.
# Generate once: python -c "from simdrive.license.keypair import generate_keypair; sk,vk = generate_keypair(); print(vk.encode().hex())"
# This value is also baked into the simdrive client binary (public_key.py).
SIMDRIVE_PUBLIC_KEY_HEX=

# Ed25519 signing (private) key — hex-encoded 64 bytes.
# KEEP SECRET. Only the Cloud API server (Railway) needs this.
# Generate alongside the public key (same command — prints the signing key seed).
SIMDRIVE_LICENSE_PRIVATE_KEY=

# ── Storage — Cloudflare R2 ───────────────────────────────────────────────────

# Cloudflare account ID (visible in R2 dashboard URL).
R2_ACCOUNT_ID=

# R2 API token — Key ID. Created in Cloudflare dashboard under
# R2 > Manage R2 API Tokens > Create API Token (Object Read & Write).
R2_ACCESS_KEY_ID=

# R2 API token — Secret. Shown ONCE at creation time; store immediately.
R2_SECRET_ACCESS_KEY=

# Bucket name. Create manually in Cloudflare R2 dashboard.
# Recommended: "simdrive-cloud-prod" for production, "simdrive-cloud-dev" for staging.
R2_BUCKET=

# Storage backend override (optional).
# Set to "stub" to force local filesystem storage (useful for local dev without R2 creds).
# Defaults to "r2" when R2_* vars are set, "stub" otherwise.
# STORAGE_BACKEND=stub

# ── Database ─────────────────────────────────────────────────────────────────

# SQLAlchemy database URL.
# For Railway: use the Railway Postgres plugin and set the connection string it provides.
# For local dev: leave unset to use SQLite (sqlite:///./simdrive_cloud.db).
# Example Railway Postgres: postgresql://user:pass@host:5432/dbname
SIMDRIVE_DATABASE_URL=

# ── Server ───────────────────────────────────────────────────────────────────

# PORT is injected automatically by Railway. Do not set manually.
# PORT=8080

# ── Domain ───────────────────────────────────────────────────────────────────

# Public hostname for the cloud API.
# Set as a Railway custom domain: cloud.simdrive.dev
# (maintainer to confirm domain before first design-partner upload.)
# SIMDRIVE_CLOUD_DOMAIN=cloud.simdrive.dev
